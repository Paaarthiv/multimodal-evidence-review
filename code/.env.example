# Copy this file to `.env` (same folder) and fill in your keys.
# NEVER commit the real .env. Secrets are read from env vars only.

# --- OpenAI (primary vision provider) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Gemini (vision provider) ---
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# --- Optional knobs ---
# PROVIDER_ORDER controls primary->fallback order. Entries are "provider" or
# "provider:model", tried left to right on hard errors.
PROVIDER_ORDER=gemini:gemini-2.5-flash,gemini:gemini-2.5-flash-lite,openai:gpt-4o
# Max concurrent claims processed at once (rate-limit friendly for the free tier)
MAX_CONCURRENCY=3
# Set to 1 to use the offline mock provider (no API calls) for pipeline testing
USE_MOCK=0
